{
  "name": "personal-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build:ai-data": "node scripts/build-ai-data.js",
    "build": "npm run build:ai-data && next build",
    "build:prod": "npm run optimize-images && npm run build",
    "start": "serve dist",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "optimize-images": "node scripts/optimize-images.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "validate-post": "node scripts/validate-post.js",
    "validate-content": "node scripts/validate-post.js"
  },
  "engines": {
    "node": ">=20 <21"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "github-slugger": "^2.0.0",
    "lucide-react": "^0.563.0",
    "next": "15.5.15",
    "next-mdx-remote": "^6.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-prism-plus": "^2.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.2.1"
  },
  "overrides": {
    "postcss": "8.5.12"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.17",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "postcss": "8.5.12",
    "serve": "14.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^3.0.5"
  }
}
