# Core Service env loading order:
# 1. core-service/.env
# 2. core-service/.env.<APP_ENV>
# 3. core-service/.env.local
# 4. core-service/.env.<APP_ENV>.local
# 5. real process env (highest priority)

APP_ENV=development
PUBLIC_SITE_URL=http://localhost:3000
API_PUBLIC_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS_RAW=
COOKIE_DOMAIN=
DATABASE_URL=sqlite+pysqlite:///./core-service/dev.db
SESSION_SECRET=replace-with-session-secret
ADMIN_SECRET_HASH=replace-with-admin-secret-hash
TURNSTILE_SECRET_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL_ID=
EMBEDDING_DIMENSIONS=1536
EMERGENCY_DISABLE_AI=false

DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
TENCENT_TOKENHUB_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
