# Core Service env checklist.
# Local: copy this file to core-service/.env.local and fill private values.
# Production: configure the same keys in Render env; do not create a production env file.

APP_ENV=local
PUBLIC_SITE_URL=http://localhost:3001
API_PUBLIC_BASE_URL=http://localhost:8001
COOKIE_DOMAIN=

# Optional config.yml overrides.
AI_ACTIVE_PROFILE=
AI_GLOBAL_DAILY_TOKEN_LIMIT=
AI_CHAT_DAILY_REQUEST_LIMIT=
AI_ADVISOR_DAILY_REQUEST_LIMIT=
AI_MODERATION_DAILY_REQUEST_LIMIT=
AI_EMBEDDING_DAILY_TOKEN_LIMIT=

DATABASE_URL=sqlite+aiosqlite:///./dev.db
SESSION_SECRET=replace-with-session-secret
ADMIN_SECRET_HASH=replace-with-admin-secret-hash
TURNSTILE_SECRET_KEY=

# RAG / embedding.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL_ID=
EMBEDDING_DIMENSIONS=1536
EMERGENCY_DISABLE_AI=false

# LLM provider keys.
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
