APP_ENV=production
PUBLIC_SITE_URL=https://yuanshenjian.cn
API_PUBLIC_BASE_URL=https://api.yuanshenjian.cn
DATABASE_URL=postgresql+psycopg://user:password@host:5432/postgres
SESSION_SECRET=replace-with-long-random-secret
ADMIN_SECRET_HASH=replace-with-hash
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=replace-with-embedding-key
EMBEDDING_MODEL_ID=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMERGENCY_DISABLE_AI=false

DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
TENCENT_TOKENHUB_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
