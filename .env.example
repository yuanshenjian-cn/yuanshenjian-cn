# 博客系统配置
# 复制此文件为 .env.local 并填写实际值

# 站点基础配置
# 博客域名（必填，用于生成 sitemap 和 robots.txt）
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# AI 助手配置
# Core Service 对外地址。前端 AI、评论和阅读统计使用该服务
NEXT_PUBLIC_CORE_SERVICE_URL=https://api.yourdomain.com
# 是否启用前端 AI 入口
NEXT_PUBLIC_AI_ENABLED=true
# 是否启用页面级 AI 助手（文章页 / 作者页）
NEXT_PUBLIC_AI_PAGE_ASSISTANT_ENABLED=true
# 是否启用页面级 AI 流式响应
NEXT_PUBLIC_AI_PAGE_ASSISTANT_STREAM_ENABLED=true
# Cloudflare Turnstile Site Key（前端公开值）
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Core Service 后端配置已迁到 `core-service/` 子工程。
# 环境变量清单见：
# - core-service/.env.example
# 结构化运行配置见：
# - core-service/app/config.yml

# Admin Console 配置（Vercel 环境变量）
VITE_CORE_SERVICE_URL=https://api.yuanshenjian.cn
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Cloudflare 定向缓存清理（可选，用于部署后自动/手动 purge 指定页面）
# Token 需要至少具备当前 Zone 的 Cache Purge 权限
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id

# Waline 评论系统配置（已弃用，保留用于参考）
# Waline 服务端地址（如使用 Waline 需要填写）
# 格式：https://your-waline-domain.vercel.app 或 https://comments.yourdomain.com
# NEXT_PUBLIC_WALINE_SERVER_URL=https://your-waline-domain.vercel.app
