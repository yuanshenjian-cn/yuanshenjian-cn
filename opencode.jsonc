{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "wenyan": {
      "type": "local",
      "command": ["wenyan-mcp"],
      "environment": {
        "WECHAT_APP_ID": "{file:.secrets/wechat_app_id}",
        "WECHAT_APP_SECRET": "{file:.secrets/wechat_app_secret}",
      },
      "enabled": true,
    },
  },
}
