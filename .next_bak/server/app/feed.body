    <item>
      <title><![CDATA[OpenCode 新手入门：从零开始使用]]></title>
      <link>https://yuanshenjian.cn/articles/2026/02/06/opencode-ai-coding-agent-getting-started</link>
      <guid isPermaLink="true">https://yuanshenjian.cn/articles/2026/02/06/opencode-ai-coding-agent-getting-started</guid>
