lock w-4 h-4","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],4," 分钟"]}]]}],["$","div",null,{"className":"flex flex-wrap gap-2 mt-4","children":[["$","$L7","职业成长",{"href":"/articles?tag=%E8%81%8C%E4%B8%9A%E6%88%90%E9%95%BF","className":"text-xs px-2 py-1 bg-muted rounded hover:bg-primary hover:text-primary-foreground transition-colors","children":"职业成长"}]]}]]}]],["$","div",null,{"className":"prose prose-neutral dark:prose-invert max-w-none","children":["$","$17",null,{"fallback":["$","div",null,{"className":"text-muted-foreground","children":"加载中..."}],"children":"$L22"}]}],["$","div",null,{"className":"mt-10","children":["$","$L23",null,{"url":"https://yuanshenjian.cn/articles/2016/03/15/5-tips-being-an-effective-tl","title":"高效技术领导的5个锦囊妙计","description":"转型为技术领导（TL）对开发人员是艰难挑战，因为管理和沟通技能不能从编码经验自动转化。高效TL的五个锦囊：1.学会委托，不独自承担所有编码工作，让团队成员获得成长机会；2.抽出时间写代码，保持对代码库的熟悉和团队成员的尊敬；3.可视化系统架构，通过白板会议和图表帮助开发人员理解系统设计与自身工作的关联；4.与团队成员一对一交流，了解每个人的目标和成长需求；5.学会说业务语言，用业务人员熟悉的术语解释技术概念，减小沟通隔阂。"}]}],null,["$","div",null,{"className":"mt-8","children":["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 gap-4","children":[["$","$L7",null,{"href":"/articles/2016/01/01/summary-for-2015","className":"group p-4 rounded-lg border hover:border-primary/50 transition-colors","children":[["$","div",null,{"className":"flex items-center gap-2 text-sm text-muted-foreground mb-1","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"上一篇"]}],["$","div",null,{"className":"font-medium text-sm line-clamp-2","children":"ThoughtWorks，我的2015"}]]}],["$","$L7",null,{"href":"/articles/2016/03/27/3-mistakes-of-first-tl","className":"group p-4 rounded-lg border hover:border-primary/50 transition-colors text-right","children":[["$","div",null,{"className":"flex items-center justify-end gap-2 text-sm text-muted-foreground mb-1","children":["下一篇",["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-right w-4 h-4","aria-hidden":"true","children":["$L24","$L25","$undefined"]}]]}],"$L26"]}]]}]}],"$L27"]}],"$L28"]}]
