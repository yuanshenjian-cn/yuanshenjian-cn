1d:["$","div",null,{"className":"my-8","children":["$","div",null,{"className":"bg-card rounded-lg p-4 border","children":["$","$L21",null,{"headings":[{"id":"敏捷宣言概览","text":"敏捷宣言概览","level":2},{"id":"敏捷宣言解读","text":"敏捷宣言解读","level":2},{"id":"以人为本","text":"以人为本","level":3},{"id":"价值导向","text":"价值导向","level":3},{"id":"客户团队","text":"客户团队","level":3},{"id":"拥抱变化","text":"拥抱变化","level":3},{"id":"写在最后","text":"写在最后","level":2}]}]}]}]
1e:["$","div",null,{"className":"w-full max-w-2xl mx-auto lg:mx-0 overflow-hidden","children":[["$","div",null,{"className":"hidden lg:block","children":[[["$","$L7",null,{"href":"/articles","className":"inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"返回文章列表"]}],["$","header",null,{"className":"mb-8","children":[["$","h1",null,{"className":"text-2xl md:text-3xl font-medium mb-4","children":"深入解读敏捷宣言"}],["$","div",null,{"className":"flex flex-wrap items-center gap-4 text-sm text-muted-foreground","children":[["$","span",null,{"className":"flex items-center gap-1","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-calendar w-4 h-4","aria-hidden":"true","children":[["$","path","1cmpym",{"d":"M8 2v4"}],["$","path","4m81vk",{"d":"M16 2v4"}],["$","rect","1hopcy",{"width":"18","height":"18","x":"3","y":"4","rx":"2"}],["$","path","8toen8",{"d":"M3 10h18"}],"$undefined"]}],["$","time",null,{"dateTime":"2018-10-30T00:00:00.000Z","children":"2018/10/30"}]]}],["$","span",null,{"children":"·"}],["$","span",null,{"className":"flex items-center gap-1","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-4 h-4","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],8," 分钟"]}]]}],["$","div",null,{"className":"flex flex-wrap gap-2 mt-4","children":[["$","$L7","软件开发",{"href":"/articles?tag=%E8%BD%AF%E4%BB%B6%E5%BC%80%E5%8F%91","className":"text-xs px-2 py-1 bg-muted rounded hover:bg-primary hover:text-primary-foreground transition-colors","children":"软件开发"}],["$","$L7","敏捷教练",{"href":"/articles?tag=%E6%95%8F%E6%8D%B7%E6%95%99%E7%BB%83","className":"text-xs px-2 py-1 bg-muted rounded hover:bg-primary hover:text-primary-foreground transition-colors","children":"敏捷教练"}]]}]]}]],["$","div",null,{"className":"prose prose-neutral dark:prose-invert max-w-none","children":["$","$17",null,{"fallback":["$","div",null,{"className":"text-muted-foreground","children":"加载中..."}],"children":"$L22"}]}],["$","div",null,{"className":"mt-10","children":["$","$L23",null,{"url":"https://yuanshenjian.cn/articles/2018/10/30/understand-agile-manifesto-deeply","title":"深入解读敏捷宣言","description":"2001年17位反叛性软件开发人员在犹他州雪鸟城制定并签署敏捷宣言。四句核心价值观：个体与交互优于流程与工具、可工作的软件优于面面俱到的文档、客户协作优于合同谈判、响应变化优于遵循计划。以人为本强调尊重信任激发个人潜能，建立自治全功能团队。价值导向以交付可工作的软件为核心，文档应有选择地保留。客户团队强调与客户建立信任合作关系取代敌对谈判。拥抱变化道出敏捷精髓——通过高效协作获取快速反馈以减少浪费。敏捷是文化价值认同，比形式更重要的是对敏捷价值观的理解和认同。"}]}],null,["$","div",null,{"className":"mt-8","children":["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 gap-4","children":[["$","$L7",null,{"href":"/articles/2018/10/19/programmer-to-trainner","className":"group p-4 rounded-lg border hover:border-primary/50 transition-colors","children":[["$","div",null,{"className":"flex items-center gap-2 text-sm text-muted-foreground mb-1","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"上一篇"]}],["$","div",null,{"className":"font-medium text-sm line-clamp-2","children":"从写代码到做培训"}]]}],["$","$L7",null,{"href":"/articles/2018/11/27/two-basic-element-of-scrum-team","className":"group p-4 rounded-lg border hover:border-primary/50 transition-colors text-right","children":[["$","div",null,{"className":"flex items-center justify-end gap-2 text-sm text-muted-foreground mb-1","children":["下一篇","$L24"]}],"$L25"]}]]}]}],"$L26"]}],"$L27"]}]
