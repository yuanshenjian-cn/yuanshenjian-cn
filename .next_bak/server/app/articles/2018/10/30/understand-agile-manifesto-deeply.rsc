6e:I[622,[],"IconMark"]
13:{"metadata":[["$","title","0",{"children":"深入解读敏捷宣言 | 袁慎建的技术博客"}],["$","meta","1",{"name":"description","content":"2001年17位反叛性软件开发人员在犹他州雪鸟城制定并签署敏捷宣言。四句核心价值观：个体与交互优于流程与工具、可工作的软件优于面面俱到的文档、客户协作优于合同谈判、响应变化优于遵循计划。以人为本强调尊重信任激发个人潜能，建立自治全功能团队。价值导向以交付可工作的软件为核心，文档应有选择地保留。客户团队强调与客户建立信任合作关系取代敌对谈判。拥抱变化道出敏捷精髓——通过高效协作获取快速反馈以减少浪费。敏捷是文化价值认同，比形式更重要的是对敏捷价值观的理解和认同。"}],["$","meta","2",{"name":"author","content":"袁慎建"}],["$","link","3",{"rel":"manifest","href":"/manifest.json","crossOrigin":"$undefined"}],["$","meta","4",{"name":"keywords","content":"软件开发,敏捷教练"}],["$","meta","5",{"name":"robots","content":"index, follow"}],["$","meta","6",{"name":"googlebot","content":"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1"}],["$","meta","7",{"name":"theme-color","content":"#000000"}],["$","meta","8",{"name":"color-scheme","content":"dark light"}],["$","link","9",{"rel":"canonical","href":"https://yuanshenjian.cn/articles/2018/10/30/understand-agile-manifesto-deeply"}],["$","meta","10",{"name":"mobile-web-app-capable","content":"yes"}],["$","meta","11",{"name":"apple-mobile-web-app-title","content":"YSJ Blog"}],["$","meta","12",{"name":"apple-mobile-web-app-status-bar-style","content":"default"}],["$","meta","13",{"property":"og:title","content":"深入解读敏捷宣言"}],["$","meta","14",{"property":"og:description","content":"2001年17位反叛性软件开发人员在犹他州雪鸟城制定并签署敏捷宣言。四句核心价值观：个体与交互优于流程与工具、可工作的软件优于面面俱到的文档、客户协作优于合同谈判、响应变化优于遵循计划。以人为本强调尊重信任激发个人潜能，建立自治全功能团队。价值导向以交付可工作的软件为核心，文档应有选择地保留。客户团队强调与客户建立信任合作关系取代敌对谈判。拥抱变化道出敏捷精髓——通过高效协作获取快速反馈以减少浪费。敏捷是文化价值认同，比形式更重要的是对敏捷价值观的理解和认同。 | 阅读约 8 分钟 | 标签: 软件开发, 敏捷教练"}],["$","meta","15",{"property":"og:url","content":"https://yuanshenjian.cn/articles/2018/10/30/understand-agile-manifesto-deeply"}],["$","meta","16",{"property":"og:site_name","content":"袁慎建的技术博客"}],["$","meta","17",{"property":"og:locale","content":"zh_CN"}],["$","meta","18",{"property":"og:image","content":"https://yuanshenjian.cn/images/og-default.webp"}],["$","meta","19",{"property":"og:image:width","content":"1200"}],["$","meta","20",{"property":"og:image:height","content":"630"}],["$","meta","21",{"property":"og:image:alt","content":"深入解读敏捷宣言"}],["$","meta","22",{"property":"og:type","content":"article"}],["$","meta","23",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","24",{"name":"twitter:site","content":"@yuanshenjian"}],["$","meta","25",{"name":"twitter:creator","content":"@yuanshenjian"}],["$","meta","26",{"name":"twitter:title","content":"深入解读敏捷宣言"}],["$","meta","27",{"name":"twitter:description","content":"2001年17位反叛性软件开发人员在犹他州雪鸟城制定并签署敏捷宣言。四句核心价值观：个体与交互优于流程与工具、可工作的软件优于面面俱到的文档、客户协作优于合同谈判、响应变化优于遵循计划。以人为本强调尊重信任激发个人潜能，建立自治全功能团队。价值导向以交付可工作的软件为核心，文档应有选择地保留。客户团队强调与客户建立信任合作关系取代敌对谈判。拥抱变化道出..."}],["$","meta","28",{"name":"twitter:image","content":"https://yuanshenjian.cn/images/og-default.webp"}],["$","link","29",{"rel":"shortcut icon","href":"/favicon.ico"}],["$","link","30",{"rel":"icon","href":"/favicon.ico"}],["$","link","31",{"rel":"apple-touch-icon","href":"/favicon.ico"}],["$","$L6e","32",{}]],"error":null,"digest":"$undefined"}
