 w-4 h-4","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],6," 分钟"]}]]}],["$","div",null,{"className":"flex flex-wrap gap-2 mt-4","children":[["$","$L7","职业成长",{"href":"/articles?tag=%E8%81%8C%E4%B8%9A%E6%88%90%E9%95%BF","className":"text-xs px-2 py-1 bg-muted rounded hover:bg-primary hover:text-primary-foreground transition-colors","children":"职业成长"}]]}]]}]],["$","div",null,{"className":"prose prose-neutral dark:prose-invert max-w-none","children":["$","$17",null,{"fallback":["$","div",null,{"className":"text-muted-foreground","children":"加载中..."}],"children":"$L22"}]}],["$","div",null,{"className":"mt-10","children":["$","$L23",null,{"url":"https://yuanshenjian.cn/articles/2018/10/19/programmer-to-trainner","title":"从写代码到做培训","description":"作为程序员工作五年后，作者踏上培训道路开始梳理总结分享。发展他人的意愿是成为培训师的基础，在ThoughtWorks被列入胜任力模型。转型前有四点顾虑：培训劳心劳体是否拖垮身体；台上讲话紧张会否被嘲笑；不会课程设计是否会误人子弟；远离一线技术是否会退化。关于培训收获，强化了沟通协作、梳理知识体系、拓展外训视野、获得认证机会。培训师面对培训无用论的回答是：培训核心作用是让你知道自己不知道，再通过知识扩充、实战操练和技能转化达到提升目的。"}]}],null,["$","div",null,{"className":"mt-8","children":["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 gap-4","children":[["$","$L7",null,{"href":"/articles/2018/08/27/three-practices-of-simple-design","className":"group p-4 rounded-lg border hover:border-primary/50 transition-colors","children":[["$","div",null,{"className":"flex items-center gap-2 text-sm text-muted-foreground mb-1","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"上一篇"]}],["$","div",null,{"className":"font-medium text-sm line-clamp-2","children":"简单设计落地三板斧"}]]}],["$","$L7",null,{"href":"/articles/2018/10/30/understand-agile-manifesto-deeply","className":"group p-4 rounded-lg border hover:border-primary/50 transition-colors text-right","children":[["$","div",null,{"className":"flex items-center justify-end gap-2 text-sm text-muted-foreground mb-1","children":["下一篇",["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-right w-4 h-4","aria-hidden":"true","children":["$L24","$L25","$undefined"]}]]}],"$L26"]}]]}]}],"$L27"]}],"$L28"]}]
