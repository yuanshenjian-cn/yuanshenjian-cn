13:{"metadata":[["$","title","0",{"children":"从写代码到做培训 | 袁慎建的技术博客"}],["$","meta","1",{"name":"description","content":"作为程序员工作五年后，作者踏上培训道路开始梳理总结分享。发展他人的意愿是成为培训师的基础，在ThoughtWorks被列入胜任力模型。转型前有四点顾虑：培训劳心劳体是否拖垮身体；台上讲话紧张会否被嘲笑；不会课程设计是否会误人子弟；远离一线技术是否会退化。关于培训收获，强化了沟通协作、梳理知识体系、拓展外训视野、获得认证机会。培训师面对培训无用论的回答是：培训核心作用是让你知道自己不知道，再通过知识扩充、实战操练和技能转化达到提升目的。"}],["$","meta","2",{"name":"author","content":"袁慎建"}],["$","link","3",{"rel":"manifest","href":"/manifest.json","crossOrigin":"$undefined"}],["$","meta","4",{"name":"keywords","content":"职业成长"}],["$","meta","5",{"name":"robots","content":"index, follow"}],["$","meta","6",{"name":"googlebot","content":"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1"}],["$","meta","7",{"name":"theme-color","content":"#000000"}],["$","meta","8",{"name":"color-scheme","content":"dark light"}],["$","link","9",{"rel":"canonical","href":"https://yuanshenjian.cn/articles/2018/10/19/programmer-to-trainner"}],["$","meta","10",{"name":"mobile-web-app-capable","content":"yes"}],["$","meta","11",{"name":"apple-mobile-web-app-title","content":"YSJ Blog"}],["$","meta","12",{"name":"apple-mobile-web-app-status-bar-style","content":"default"}],["$","meta","13",{"property":"og:title","content":"从写代码到做培训"}],["$","meta","14",{"property":"og:description","content":"作为程序员工作五年后，作者踏上培训道路开始梳理总结分享。发展他人的意愿是成为培训师的基础，在ThoughtWorks被列入胜任力模型。转型前有四点顾虑：培训劳心劳体是否拖垮身体；台上讲话紧张会否被嘲笑；不会课程设计是否会误人子弟；远离一线技术是否会退化。关于培训收获，强化了沟通协作、梳理知识体系、拓展外训视野、获得认证机会。培训师面对培训无用论的回答是：培训核心作用是让你知道自己不知道，再通过知识扩充、实战操练和技能转化达到提升目的。 | 阅读约 6 分钟 | 标签: 职业成长"}],["$","meta","15",{"property":"og:url","content":"https://yuanshenjian.cn/articles/2018/10/19/programmer-to-trainner"}],["$","meta","16",{"property":"og:site_name","content":"袁慎建的技术博客"}],["$","meta","17",{"property":"og:locale","content":"zh_CN"}],["$","meta","18",{"property":"og:image","content":"https://yuanshenjian.cn/images/og-default.webp"}],["$","meta","19",{"property":"og:image:width","content":"1200"}],["$","meta","20",{"property":"og:image:height","content":"630"}],["$","meta","21",{"property":"og:image:alt","content":"从写代码到做培训"}],["$","meta","22",{"property":"og:type","content":"article"}],["$","meta","23",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","24",{"name":"twitter:site","content":"@yuanshenjian"}],["$","meta","25",{"name":"twitter:creator","content":"@yuanshenjian"}],["$","meta","26",{"name":"twitter:title","content":"从写代码到做培训"}],["$","meta","27",{"name":"twitter:description","content":"作为程序员工作五年后，作者踏上培训道路开始梳理总结分享。发展他人的意愿是成为培训师的基础，在ThoughtWorks被列入胜任力模型。转型前有四点顾虑：培训劳心劳体是否拖垮身体；台上讲话紧张会否被嘲笑；不会课程设计是否会误人子弟；远离一线技术是否会退化。关于培训收获，强化了沟通协作、梳理知识体系、拓展外训视野、获得认证机会。培训师面对培训无用论的回答是..."}],["$","meta","28",{"name":"twitter:image","content":"https://yuanshenjian.cn/images/og-default.webp"}],["$","link","29",{"rel":"shortcut icon","href":"/favicon.ico"}],["$","link","30",{"rel":"icon","href":"/favicon.ico"}],["$","link","31",{"rel":"apple-touch-icon","href":"/favicon.ico"}],["$","$L74","32",{}]],"error":null,"digest":"$undefined"}
