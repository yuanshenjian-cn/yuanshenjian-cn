1d:["$","$L21",null,{"headings":[{"id":"发展他人的意愿是基石","text":"发展他人的意愿是基石","level":2},{"id":"转型前的顾虑","text":"转型前的顾虑","level":2},{"id":"培训劳心劳体身体会不会拖垮","text":"培训劳心劳体，身体会不会拖垮？","level":3},{"id":"台上讲话紧张会不会被人嘲笑","text":"台上讲话紧张，会不会被人嘲笑？","level":3},{"id":"不会课程设计会不会误人子弟","text":"不会课程设计，会不会误人子弟？","level":3},{"id":"远离一线项目技术会不会退化","text":"远离一线项目，技术会不会退化？","level":3},{"id":"培训中的收获","text":"培训中的收获","level":2},{"id":"强化沟通协作","text":"强化沟通协作","level":3},{"id":"梳理知识体系","text":"梳理知识体系","level":3},{"id":"拓展外训视野","text":"拓展外训视野","level":3},{"id":"获得认证机会","text":"获得认证机会","level":3},{"id":"培训中的困惑","text":"培训中的困惑","level":2},{"id":"如何看待培训无用论","text":"如何看待培训无用论？","level":3},{"id":"如何保证持续的输入","text":"如何保证持续的输入？","level":3},{"id":"未来的路","text":"未来的路","level":2},{"id":"注释","text":"注释","level":2}]}]
