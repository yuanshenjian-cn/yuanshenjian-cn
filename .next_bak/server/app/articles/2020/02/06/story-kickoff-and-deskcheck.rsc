1c:T5de,[{"@context":"https://schema.org","@type":"BlogPosting","headline":"故事的首尾呼应","description":"介绍用户故事开发中的两个轻量级实践：Story Kick Off（开卡）和 Story Desk Check（验卡）。通过情景再现的方式说明这两个实践如何帮助团队在开发前达成需求共识、在开发后快速验收，通过前置反馈减少返工浪费，确保团队始终在做正确的事情。","url":"https://yuanshenjian.cn/articles/2020/02/06/story-kickoff-and-deskcheck","datePublished":"2020-02-06T00:00:00.000Z","dateModified":"2020-02-06T00:00:00.000Z","author":{"@type":"Person","name":"袁慎建","url":"https://yuanshenjian.cn","sameAs":[]},"publisher":{"@type":"Organization","name":"袁慎建的技术博客","logo":{"@type":"ImageObject","url":"https://yuanshenjian.cn/favicon.ico"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://yuanshenjian.cn/articles/2020/02/06/story-kickoff-and-deskcheck"},"keywords":"软件开发, 极限编程","articleSection":"swd","wordCount":167,"timeRequired":"PT10M","inLanguage":"zh-CN","isAccessibleForFree":true},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"首页","item":"https://yuanshenjian.cn"},{"@type":"ListItem","position":2,"name":"文章","item":"https://yuanshenjian.cn/articles"},{"@type":"ListItem","position":3,"name":"故事的首尾呼应","item":"https://yuanshenjian.cn/articles/2020/02/06/story-kickoff-and-deskcheck"}]}]f:[["$","$L1a",null,{}],["$","$L1b",null,{"id":"json-ld","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1c"}}],["$","article",null,{"className":"py-12 px-6","children":["$","div",null,{"className":"max-w-6xl mx-auto lg:flex lg:justify-center lg:gap-8","children":[["$","div",null,{"className":"lg:hidden max-w-2xl mx-auto mb-8","children":[[["$","$L7",null,{"href":"/articles","className":"inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","classNa