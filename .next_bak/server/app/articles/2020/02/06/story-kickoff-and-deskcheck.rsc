1d:["$","div",null,{"className":"my-8","children":["$","div",null,{"className":"bg-card rounded-lg p-4 border","children":["$","$L21",null,{"headings":[{"id":"剧情还原","text":"剧情还原","level":2},{"id":"首story-kick-off","text":"首：Story Kick off","level":3},{"id":"尾story-deck-check","text":"尾：Story Deck check","level":3},{"id":"剧情复盘","text":"剧情复盘","level":2},{"id":"首尾呼应的要领","text":"首尾呼应的要领","level":2},{"id":"kick-off-业务价值","text":"Kick off 业务价值","level":3},{"id":"kick-off-跨功能需求","text":"Kick off 跨功能需求","level":3},{"id":"desk-check-边界场景","text":"Desk check 边界场景","level":3},{"id":"buffer-加持技巧","text":"Buffer 加持技巧","level":3},{"id":"现实障碍","text":"现实障碍","level":2},{"id":"小结","text":"小结","level":2},{"id":"下集预告","text":"下集预告","level":2}]}]}]}]
