4 h-4","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],10," 分钟"]}]]}],["$","div",null,{"className":"flex flex-wrap gap-2 mt-4","children":[["$","$L7","软件开发",{"href":"/articles?tag=%E8%BD%AF%E4%BB%B6%E5%BC%80%E5%8F%91","className":"text-xs px-2 py-1 bg-muted rounded hover:bg-primary hover:text-primary-foreground transition-colors","children":"软件开发"}],["$","$L7","极限编程",{"href":"/articles?tag=%E6%9E%81%E9%99%90%E7%BC%96%E7%A8%8B","className":"text-xs px-2 py-1 bg-muted rounded hover:bg-primary hover:text-primary-foreground transition-colors","children":"极限编程"}]]}]]}]],["$","div",null,{"className":"prose prose-neutral dark:prose-invert max-w-none","children":["$","$17",null,{"fallback":["$","div",null,{"className":"text-muted-foreground","children":"加载中..."}],"children":"$L22"}]}],["$","div",null,{"className":"mt-10","children":["$","$L23",null,{"url":"https://yuanshenjian.cn/articles/2020/02/06/story-kickoff-and-deskcheck","title":"故事的首尾呼应","description":"介绍用户故事开发中的两个轻量级实践：Story Kick Off（开卡）和 Story Desk Check（验卡）。通过情景再现的方式说明这两个实践如何帮助团队在开发前达成需求共识、在开发后快速验收，通过前置反馈减少返工浪费，确保团队始终在做正确的事情。"}]}],null,["$","div",null,{"className":"mt-8","children":["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 gap-4","children":[["$","$L7",null,{"href":"/articles/2020/01/02/mocks-arent-stubs","className":"group p-4 rounded-lg border hover:border-primary/50 transition-colors","children":[["$","div",null,{"className":"flex items-center gap-2 text-sm text-muted-foreground mb-1","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"上一篇"]}],["$","div",null,{"className":"font-medium text-sm line-clamp-2","children":"Mocks 不是 Stubs"}]]}],["$","$L7",null,{"href":"/articles/2020/02/09/tcr-is-not-best-practice","className":"group p-4 rounded-lg border hover:border-primary/50 transition-colors text-right","children":[["$","div",null,{"className":"flex items-center justify-end gap-2 text-sm text-muted-foreground mb-1","children":["下一篇",["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-right w-4 h-4","aria-hidden":"true","children":["$L24","$L25","$undefined"]}]]}],"$L26"]}]]}]}],"$L27"]}],"$L28"]}]
