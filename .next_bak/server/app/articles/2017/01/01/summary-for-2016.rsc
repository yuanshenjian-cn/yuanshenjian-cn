2a:[["$","hr",null,{"className":"my-8 border-border"}],"\n",["$","h2",null,{"id":"匆匆那年","className":"text-2xl font-bold mt-12 mb-3 scroll-mt-24","children":"匆匆那年"}],"\n",["$","p",null,{"className":"my-4 leading-relaxed break-words","children":["翻开自己的博客，重新读过 ThoughtWorks，我的2015\n这篇文章，感觉那时的我像是一个小孩吃到了期盼已久的糖果果，好奇心得到满足，并且也体会到了糖果的来之不易，拥有后倍加珍惜，而且享受其中。2015年，经历了",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"入职"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"Shadow(Off Shore)"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"On Beach"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"国内出差"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"国外出差"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"Billable(Off Shore)"}],"，转了一圈又回到了Off Shore。这一回就是一年有余，从去年11月份到现在，整个2016年，相同的是我一直在作战在同一个Team中，不同的是："]}],"\n",["$","ul",null,{"className":"list-disc list-outside pl-5 my-4 space-y-2","children":["\n",["$","li",null,{"className":"my-1 break-words pl-1","children":["项目： ",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"E"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"P"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"C"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"P Phase2"}]]}],"\n",["$","li",null,{"className":"my-1 break-words pl-1","children":["角色： ",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"Dev"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"Android DEV"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"Core DEV"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"Tech Lead"}]]}],"\n",["$","li",null,{"className":"my-1 break-words pl-1","children":["技术： ",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"Angular JS"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"Python(Django)"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"Ruby(Rails)"}],"-->",["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"Android(Java)"}]]}],"\n",["$","li",null,{"className":"my-1 break-words pl-1","children":["组名： ","$L5f","-->","$L60","-->","$L61"]}],"\n"]}],"\n","$L62","\n","$L63","\n","$L64","\n","$L65","\n","$L66","\n","$L67","\n","$L68","\n","$L69","\n