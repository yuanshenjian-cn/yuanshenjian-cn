165:["$","$L1b4",null,{"children":["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"# 添加 stdio 服务器\nclaude mcp add my-db -- npx @modelcontextprotocol/server-postgres\n\n# 添加 HTTP 服务器\nclaude mcp add --transport http remote-api https://mcp.example.com/api\n\n# 指定作用域\nclaude mcp add my-tool --scope project -- npx my-tool-server\n\n# 列出已配置的服务器\nclaude mcp list\n\n# 移除服务器\nclaude mcp remove my-db\n"}]}]
