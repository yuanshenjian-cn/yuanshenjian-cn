1c:T5b2,[{"@context":"https://schema.org","@type":"BlogPosting","headline":"Claude Code 第六篇：设置、权限与 Auto Mode","description":"深入 Claude Code 的四层设置体系、细粒度权限规则语法、Auto Mode 分类器配置与沙箱化纵深防御，帮你在安全与效率之间找到最佳平衡点。","url":"https://yuanshenjian.cn/articles/2026/04/06/claude-code-settings-and-permissions","datePublished":"2026-04-06T00:00:00.000Z","dateModified":"2026-04-06T00:00:00.000Z","author":{"@type":"Person","name":"袁慎建","url":"https://yuanshenjian.cn","sameAs":[]},"publisher":{"@type":"Organization","name":"袁慎建的技术博客","logo":{"@type":"ImageObject","url":"https://yuanshenjian.cn/favicon.ico"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://yuanshenjian.cn/articles/2026/04/06/claude-code-settings-and-permissions"},"keywords":"软件开发, AI 编程, ClaudeCode","articleSection":"swd","wordCount":2159,"timeRequired":"PT12M","inLanguage":"zh-CN","isAccessibleForFree":true},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"首页","item":"https://yuanshenjian.cn"},{"@type":"ListItem","position":2,"name":"文章","item":"https://yuanshenjian.cn/articles"},{"@type":"ListItem","position":3,"name":"Claude Code 第六篇：设置、权限与 Auto Mode","item":"https://yuanshenjian.cn/articles/2026/04/06/claude-code-settings-and-permissions"}]}]f:[["$","$L1a",null,{}],["$","$L1b",null,{"id":"json-ld","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1c"}}],["$","article",null,{"className":"py-12 px-6","children":["$","div",null,{"className":"max-w-6xl mx-auto lg:flex lg:justify-center lg:gap-8","children":[["$","div",null,{"className":"lg:hidden max-w-2xl mx-auto mb-8","children":[[["$","$L7",null,{"href":"/articles","className":"inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"ro