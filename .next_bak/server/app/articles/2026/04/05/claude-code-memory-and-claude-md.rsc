1c:T661,[{"@context":"https://schema.org","@type":"BlogPosting","headline":"Claude Code 第五篇：记忆层——CLAUDE.md、Rules 与 Auto Memory","description":"Claude Code 每次启动都是一张白纸——除非你给它\"记忆\"。CLAUDE.md 是你写给 Claude 的操作手册，Rules 是模块化的规则引擎，Auto Memory 是 Claude 自己的笔记本。三者配合，让 Claude 不再每次都从零开始。本文详解三套记忆系统的机制、写法与实战模式。","url":"https://yuanshenjian.cn/articles/2026/04/05/claude-code-memory-and-claude-md","datePublished":"2026-04-05T00:00:00.000Z","dateModified":"2026-04-05T00:00:00.000Z","author":{"@type":"Person","name":"袁慎建","url":"https://yuanshenjian.cn","sameAs":[]},"publisher":{"@type":"Organization","name":"袁慎建的技术博客","logo":{"@type":"ImageObject","url":"https://yuanshenjian.cn/favicon.ico"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://yuanshenjian.cn/articles/2026/04/05/claude-code-memory-and-claude-md"},"keywords":"软件开发, AI 编程, ClaudeCode","articleSection":"swd","wordCount":2016,"timeRequired":"PT11M","inLanguage":"zh-CN","isAccessibleForFree":true},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"首页","item":"https://yuanshenjian.cn"},{"@type":"ListItem","position":2,"name":"文章","item":"https://yuanshenjian.cn/articles"},{"@type":"ListItem","position":3,"name":"Claude Code 第五篇：记忆层——CLAUDE.md、Rules 与 Auto Memory","item":"https://yuanshenjian.cn/articles/2026/04/05/claude-code-memory-and-claude-md"}]}]f:[["$","$L1a",null,{}],["$","$L1b",null,{"id":"json-ld","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1c"}}],["$","article",null,{"className":"py-12 px-6","children":["$","div",null,{"className":"max-w-6xl mx-auto lg:flex lg:justify-center lg:gap-8","children":[["$","div",null,{"className":"lg:hidden max-w-2xl mx-auto mb-8","children":[[["$","$L7",null,{"href":"/articles","className":"inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"hei