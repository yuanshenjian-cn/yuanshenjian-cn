15f:["$","h3",null,{"id":"组合技一plan--execute--verify","className":"text-xl font-semibold mt-8 mb-2 scroll-mt-24","children":"组合技一：Plan → Execute → Verify"}]
160:["$","$L172",null,{"children":["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"# 第一步：Plan 模式分析（按 Shift+Tab 切到 Plan）\n分析 @src/auth/ 目录的认证逻辑，给出从 JWT 迁移到 Session 的方案\n\n# 第二步：确认方案后切到 Accept Edits（Shift+Tab）\n按照刚才的方案执行迁移\n\n# 第三步：切回 Default 模式（Shift+Tab），逐个确认命令\n跑一下测试看有没有回归\n"}]}]
161:["$","h3",null,{"id":"组合技二后台服务--前台开发","className":"text-xl font-semibold mt-8 mb-2 scroll-mt-24","children":"组合技二：后台服务 + 前台开发"}]
162:["$","$L172",null,{"children":["$","code",null,{"className":"bg-muted text-slate-800 dark:text-foreground px-1.5 py-0.5 rounded text-sm font-normal font-mono break-all","children":"# Ctrl+B 启动后台进程\nnpm run dev\n\n# 前台继续工作\n修改 @src/pages/Login.tsx，添加\"记住我\"功能\n\n# 改完后\n! curl http://localhost:3000/api/auth/session  # ! 快速验证\n"}]}]
