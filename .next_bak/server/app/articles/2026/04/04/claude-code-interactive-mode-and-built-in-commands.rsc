1c:T690,[{"@context":"https://schema.org","@type":"BlogPosting","headline":"Claude Code 第四篇：交互模式、内置命令与上下文管理","description":"Claude Code 的交互终端远不止\"打字→回车\"。六种权限模式、60+ 条内置命令、快捷键组合、上下文管理策略——掌握这些，你才算真正\"住进\"了 Claude Code。本文带你从权限模式、键盘操控、命令体系到上下文管理，逐层拆解 Claude Code 的交互全貌。","url":"https://yuanshenjian.cn/articles/2026/04/04/claude-code-interactive-mode-and-built-in-commands","datePublished":"2026-04-04T00:00:00.000Z","dateModified":"2026-04-04T00:00:00.000Z","author":{"@type":"Person","name":"袁慎建","url":"https://yuanshenjian.cn","sameAs":[]},"publisher":{"@type":"Organization","name":"袁慎建的技术博客","logo":{"@type":"ImageObject","url":"https://yuanshenjian.cn/favicon.ico"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://yuanshenjian.cn/articles/2026/04/04/claude-code-interactive-mode-and-built-in-commands"},"keywords":"软件开发, AI 编程, ClaudeCode","articleSection":"swd","wordCount":1900,"timeRequired":"PT12M","inLanguage":"zh-CN","isAccessibleForFree":true},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"首页","item":"https://yuanshenjian.cn"},{"@type":"ListItem","position":2,"name":"文章","item":"https://yuanshenjian.cn/articles"},{"@type":"ListItem","position":3,"name":"Claude Code 第四篇：交互模式、内置命令与上下文管理","item":"https://yuanshenjian.cn/articles/2026/04/04/claude-code-interactive-mode-and-built-in-commands"}]}]f:[["$","$L1a",null,{}],["$","$L1b",null,{"id":"json-ld","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1c"}}],["$","article",null,{"className":"py-12 px-6","children":["$","div",null,{"className":"max-w-6xl mx-auto lg:flex lg:justify-center lg:gap-8","children":[["$","div",null,{"className":"lg:hidden max-w-2xl mx-auto mb-8","children":[[["$","$L7",null,{"href":"/articles","className":"inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"