1c:T5cc,[{"@context":"https://schema.org","@type":"BlogPosting","headline":"OpenCode Agent 速查手册","description":"OpenCode 的 Sub Agent 功能让 AI 编程助手从单一对话模式升级为多代理协作系统。本文详细介绍 Primary Agent 与 Sub Agent 的区别、内置代理类型、配置方法以及实战使用技巧，帮助你构建更高效的 AI 辅助开发工作流。","url":"https://yuanshenjian.cn/articles/2026/02/09/opencode-agent-quick-reference","datePublished":"2026-02-09T00:00:00.000Z","dateModified":"2026-02-09T00:00:00.000Z","author":{"@type":"Person","name":"袁慎建","url":"https://yuanshenjian.cn","sameAs":[]},"publisher":{"@type":"Organization","name":"袁慎建的技术博客","logo":{"@type":"ImageObject","url":"https://yuanshenjian.cn/favicon.ico"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://yuanshenjian.cn/articles/2026/02/09/opencode-agent-quick-reference"},"keywords":"软件开发, AI 编程, OpenCode","articleSection":"swd","wordCount":1229,"timeRequired":"PT5M","inLanguage":"zh-CN","isAccessibleForFree":true},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"首页","item":"https://yuanshenjian.cn"},{"@type":"ListItem","position":2,"name":"文章","item":"https://yuanshenjian.cn/articles"},{"@type":"ListItem","position":3,"name":"OpenCode Agent 速查手册","item":"https://yuanshenjian.cn/articles/2026/02/09/opencode-agent-quick-reference"}]}]f:[["$","$L1a",null,{}],["$","$L1b",null,{"id":"json-ld","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1c"}}],["$","article",null,{"className":"py-12 px-6","children":["$","div",null,{"className":"max-w-6xl mx-auto lg:flex lg:justify-center lg:gap-8","children":[["$","div",null,{"className":"lg:hidden max-w-2xl mx-auto mb-8","children":[[["$","$L7",null,{"href":"/articles","className":"inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLineca