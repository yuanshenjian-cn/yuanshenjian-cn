13:{"metadata":[["$","title","0",{"children":"Oh My OpenCode：Atlas vs Sisyphus 双 orchestrator 架构解析 | 袁慎建的技术博客"}],["$","meta","1",{"name":"description","content":"Atlas 和 Sisyphus 是 OhMyOpenCode 插件中的两个核心 orchestrator 代理。Sisyphus 定位为全能主协调器，负责意图解析、动态规划和智能委派，拥有完整的工具权限但不能直接调用特定代理。Atlas 则是纯协调指挥家，不直接写代码，专注于协调和验证，通过 4-Phase QA Protocol 严格验证每个委派任务。两者在代码权限、适用场景、状态管理、并行策略和验证职责等方面有本质差异，分别代表了高级工程师和技术负责人两种不同的 orchestration 哲学。"}],["$","meta","2",{"name":"author","content":"袁慎建"}],["$","link","3",{"rel":"manifest","href":"/manifest.json","crossOrigin":"$undefined"}],["$","meta","4",{"name":"keywords","content":"软件开发,AI 编程,OpenCode,Oh My OpenCode"}],["$","meta","5",{"name":"robots","content":"index, follow"}],["$","meta","6",{"name":"googlebot","content":"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1"}],["$","meta","7",{"name":"theme-color","content":"#000000"}],["$","meta","8",{"name":"color-scheme","content":"dark light"}],["$","link","9",{"rel":"canonical","href":"https://yuanshenjian.cn/articles/2026/02/24/oh-my-opencode-atlas-vs-sisyphus-arch"}],["$","meta","10",{"name":"mobile-web-app-capable","content":"yes"}],["$","meta","11",{"name":"apple-mobile-web-app-title","content":"YSJ Blog"}],["$","meta","12",{"name":"apple-mobile-web-app-status-bar-style","content":"default"}],["$","meta","13",{"property":"og:title","content":"Oh My OpenCode：Atlas vs Sisyphus 双 orchestrator 架构解析"}],["$","meta","14",{"property":"og:description","content":"Atlas 和 Sisyphus 是 OhMyOpenCode 插件中的两个核心 orchestrator 代理。Sisyphus 定位为全能主协调器，负责意图解析、动态规划和智能委派，拥有完整的工具权限但不能直接调用特定代理。Atlas 则是纯协调指挥家，不直接写代码，专注于协调和验证，通过 4-Phase QA Protocol 严格验证每个委派任务。两者在代码权限、适用场景、状态管理、并行策略和验证职责等方面有本质差异，分别代表了高级工程师和技术负责人两种不同的 orchestration 哲学。 | 阅读约 8 分钟 | 标签: 软件开发, AI 编程, OpenCode"}],["$","meta","15",{"property":"og:url","content":"https://yuanshenjian.cn/articles/2026/02/24/oh-my-opencode-atlas-vs-sisyphus-arch"}],["$","meta","16",{"property":"og:site_name","content":"袁慎建的技术博客"}],["$","meta","17",{"prope