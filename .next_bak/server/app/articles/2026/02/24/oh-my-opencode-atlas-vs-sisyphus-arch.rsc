 py-2 break-words min-w-[100px]","children":["$","strong",null,{"children":"状态管理"}]}],["$","td",null,{"className":"border border-border px-4 py-2 break-words min-w-[100px]","children":"当前会话的 todo API"}],["$","td",null,{"className":"border border-border px-4 py-2 break-words min-w-[100px]","children":"Boulder State JSON + Notepad"}]]}],["$","tr",null,{"children":[["$","td",null,{"className":"border border-border px-4 py-2 break-words min-w-[100px]","children":["$","strong",null,{"children":"并行策略"}]}],["$","td",null,{"className":"border border-border px-4 py-2 break-words min-w-[100px]","children":"探索类任务后台并行"}],["$","td",null,{"className":"border border-border px-4 py-2 break-words min-w-[100px]","children":"执行类任务前台并行（多 subagent）"}]]}],["$","tr",null,{"children":[["$","td",null,{"className":"border border-border px-4 py-2 break-words min-w-[100px]","children":["$","strong",null,{"children":"验证职责"}]}],["$","td",null,{"className":"border border-border px-4 py-2 break-words min-w-[100px]","children":"自我验证"}],["$","td",null,{"className":"border border-border px-4 py-2 break-words min-w-[100px]","children":[["$","strong",null,{"children":"强制 QA Gate"}],"（4-Phase Protocol）"]}]]}],["$","tr",null,{"children":[["$","td",null,{"className":"border border-border px-4 py-2 break-words min-w-[100px]","children":["$","strong",null,{"children":"模型要求"}]}],["$","td",null,{"className":"border border-border px-4 py-2 break-words min-w-[100px]","children":"claude-opus-4-6 / kimi-k2.5"}],["$","td",null,{"className":"border border-border px-4 py-2 break-words min-w-[100px]","children":"kimi-k2.5 / claude-sonnet-4-6"}]]}]]}]]}]}]
