1c:T5a4,[{"@context":"https://schema.org","@type":"BlogPosting","headline":"OpenCode 基础使用：提升编程效率的技巧","description":"掌握 OpenCode 的一些基础使用技巧，从初级自然语言提问到高级自定义配置，通过实战案例学习如何用 AI Coding Agent 提升编码效率。","url":"https://yuanshenjian.cn/articles/2026/02/07/opencode-advanced-tips-and-practices","datePublished":"2026-02-07T00:00:00.000Z","dateModified":"2026-02-07T00:00:00.000Z","author":{"@type":"Person","name":"袁慎建","url":"https://yuanshenjian.cn","sameAs":[]},"publisher":{"@type":"Organization","name":"袁慎建的技术博客","logo":{"@type":"ImageObject","url":"https://yuanshenjian.cn/favicon.ico"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://yuanshenjian.cn/articles/2026/02/07/opencode-advanced-tips-and-practices"},"keywords":"软件开发, AI 编程, OpenCode","articleSection":"swd","wordCount":902,"timeRequired":"PT8M","inLanguage":"zh-CN","isAccessibleForFree":true},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"首页","item":"https://yuanshenjian.cn"},{"@type":"ListItem","position":2,"name":"文章","item":"https://yuanshenjian.cn/articles"},{"@type":"ListItem","position":3,"name":"OpenCode 基础使用：提升编程效率的技巧","item":"https://yuanshenjian.cn/articles/2026/02/07/opencode-advanced-tips-and-practices"}]}]f:[["$","$L1a",null,{}],["$","$L1b",null,{"id":"json-ld","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1c"}}],["$","article",null,{"className":"py-12 px-6","children":["$","div",null,{"className":"max-w-6xl mx-auto lg:flex lg:justify-center lg:gap-8","children":[["$","div",null,{"className":"lg:hidden max-w-2xl mx-auto mb-8","children":[[["$","$L7",null,{"href":"/articles","className":"inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":