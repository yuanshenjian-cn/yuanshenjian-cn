13:{"metadata":[["$","title","0",{"children":"Oh My OpenCode：Agent 速查手册 | 袁慎建的技术博客"}],["$","meta","1",{"name":"description","content":"Oh My OpenCode Agent 系统完全指南，面向初学者深入解析 AI agent 工作原理。系统共有 11 个 AI agent，分为 Primary Agents（主 agent）和 Sub Agents（子 agent）两大类。主 agent 包括西西弗斯、赫菲斯托斯、阿特拉斯和普罗米修斯，负责复杂任务编排、端到端功能实现、长期项目管理和战略规划。子 agent 提供预规划分析、计划验证、架构咨询、文档搜索等专业化支持。本指南详细介绍每个 agent 的角色定位、工作机制、适用场景和最佳实践，帮助开发者高效选择和使用合适的 agent 完成任务。"}],["$","meta","2",{"name":"author","content":"袁慎建"}],["$","link","3",{"rel":"manifest","href":"/manifest.json","crossOrigin":"$undefined"}],["$","meta","4",{"name":"keywords","content":"软件开发,AI 编程,OpenCode,Oh My OpenCode"}],["$","meta","5",{"name":"robots","content":"index, follow"}],["$","meta","6",{"name":"googlebot","content":"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1"}],["$","meta","7",{"name":"theme-color","content":"#000000"}],["$","meta","8",{"name":"color-scheme","content":"dark light"}],["$","link","9",{"rel":"canonical","href":"https://yuanshenjian.cn/articles/2026/02/10/oh-my-opencode-agents-quick-reference"}],["$","meta","10",{"name":"mobile-web-app-capable","content":"yes"}],["$","meta","11",{"name":"apple-mobile-web-app-title","content":"YSJ Blog"}],["$","meta","12",{"name":"apple-mobile-web-app-status-bar-style","content":"default"}],["$","meta","13",{"property":"og:title","content":"Oh My OpenCode：Agent 速查手册"}],["$","meta","14",{"property":"og:description","content":"Oh My OpenCode Agent 系统完全指南，面向初学者深入解析 AI agent 工作原理。系统共有 11 个 AI agent，分为 Primary Agents（主 agent）和 Sub Agents（子 agent）两大类。主 agent 包括西西弗斯、赫菲斯托斯、阿特拉斯和普罗米修斯，负责复杂任务编排、端到端功能实现、长期项目管理和战略规划。子 agent 提供预规划分析、计划验证、架构咨询、文档搜索等专业化支持。本指南详细介绍每个 agent 的角色定位、工作机制、适用场景和最佳实践，帮助开发者高效选择和使用合适的 agent 完成任务。 | 阅读约 13 分钟 | 标签: 软件开发, AI 编程, OpenCode"}],["$","meta","15",{"property":"og:url","content":"https://yuanshenjian.cn/articles/2026/02/10/oh-my-opencode-agents-quick-reference"}],["$","meta","16",{"property":"og:site_name","content":"袁慎建的技术博客"}],["$","meta","17",