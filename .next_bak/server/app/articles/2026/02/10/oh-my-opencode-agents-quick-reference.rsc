1c:T766,[{"@context":"https://schema.org","@type":"BlogPosting","headline":"Oh My OpenCode：Agent 速查手册","description":"Oh My OpenCode Agent 系统完全指南，面向初学者深入解析 AI agent 工作原理。系统共有 11 个 AI agent，分为 Primary Agents（主 agent）和 Sub Agents（子 agent）两大类。主 agent 包括西西弗斯、赫菲斯托斯、阿特拉斯和普罗米修斯，负责复杂任务编排、端到端功能实现、长期项目管理和战略规划。子 agent 提供预规划分析、计划验证、架构咨询、文档搜索等专业化支持。本指南详细介绍每个 agent 的角色定位、工作机制、适用场景和最佳实践，帮助开发者高效选择和使用合适的 agent 完成任务。","url":"https://yuanshenjian.cn/articles/2026/02/10/oh-my-opencode-agents-quick-reference","datePublished":"2026-02-10T00:00:00.000Z","dateModified":"2026-02-10T00:00:00.000Z","author":{"@type":"Person","name":"袁慎建","url":"https://yuanshenjian.cn","sameAs":[]},"publisher":{"@type":"Organization","name":"袁慎建的技术博客","logo":{"@type":"ImageObject","url":"https://yuanshenjian.cn/favicon.ico"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://yuanshenjian.cn/articles/2026/02/10/oh-my-opencode-agents-quick-reference"},"keywords":"软件开发, AI 编程, OpenCode, Oh My OpenCode","articleSection":"swd","wordCount":2421,"timeRequired":"PT13M","inLanguage":"zh-CN","isAccessibleForFree":true},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"首页","item":"https://yuanshenjian.cn"},{"@type":"ListItem","position":2,"name":"文章","item":"https://yuanshenjian.cn/articles"},{"@type":"ListItem","position":3,"name":"Oh My OpenCode：Agent 速查手册","item":"https://yuanshenjian.cn/articles/2026/02/10/oh-my-opencode-agents-quick-reference"}]}]f:[["$","$L1a",null,{}],["$","$L1b",null,{"id":"json-ld","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1c"}}],["$","article",null,{"className":"py-12 px-6","children":["$","div",null,{"className":"max-w-6xl mx-auto lg:flex lg:justify-center lg:gap-8","children":[["$","div",null,{"className":"lg:hidden max-w-2xl mx-auto mb-8","children":[[["$","$L7",null,{"href":"/articles","className":"inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"返回文章列表"]}],["$","header",null,{"className":"mb-8","children":[["$","h1",null,{"className":"text-2xl md:text-3xl font-medium mb-4","children":"Oh My OpenCode：Agent 速查手册"}],["$","div",null,{"className":"flex flex-wrap items-center gap-4 text-sm text-muted-foreground","children":[["$","span",null,{"className":"flex items-center gap-1","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-calendar w-4 h-4","aria-hidden":"true","children":[["$","path","1cmpym",{"d":"M8 2v4"}],["$","path","4m81vk",{"d":"M16 2v4"}],["$","rect","1hopcy",{"width":"18","height":"18","x":"3","y":"4","rx":"2"}],["$","path","8toen8",{"d":"M3 10h18"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-02-10T00:00:00.000Z","children":"2026/2/10"}]]}],["$","span",null,{"children":"·"}],["$","span",null,{"className":"flex items-center gap-1","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-4 h-4","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],13," 分钟"]}]]}],["$","div",null,{"className":"flex flex-wrap gap-2 mt-4","children":[["$","$L7","软件开发",{"href":"/articles?tag=%E8%BD%AF%E4%BB%B6%E5%BC%80%E5%8F%91","className":"text-xs px-2 py-1 bg-muted rounded hover:bg-primary hover:text-primary-foreground transition-colors","children":"软件开发"}],"$L1d","$L1e","$L1f"]}]]}]],"$L20"]}],"$L21","$L22"]}]}],"$L23"]
